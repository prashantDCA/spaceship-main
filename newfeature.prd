## 12. Error Handling

### 12.1 Error States

```typescript
// Consistent error handling
interface ErrorStates {
  network: "Unable to connect. Please check your internet connection.";
  permission: "You don't have permission to view this client.";
  notFound: "Client not found.";
  validation: "Please check the form for errors.";
  server: "Something went wrong. Please try again.";
}

// Error boundary for client sections
export function ClientErrorBoundary({ children }: { children: React.ReactNode }) {
  return (
    <ErrorBoundary fallback={<ClientErrorFallback />}>
      {children}
    </ErrorBoundary>
  );
}
```

