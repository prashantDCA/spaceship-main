## 3. Data Model

### 3.1 Database Schema Extensions

```sql
-- Client Types Enum
CREATE TYPE client_type AS ENUM ('politician', 'corporate', 'ngo', 'government_body');
CREATE TYPE client_status AS ENUM ('active', 'inactive', 'prospect', 'archived');

-- Main Clients Table
CREATE TABLE clients (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    client_type client_type NOT NULL,
    status client_status DEFAULT 'active',
    
    -- Basic Information
    name VARCHAR(255) NOT NULL,
    display_name VARCHAR(255),
    slug VARCHAR(255) UNIQUE NOT NULL, -- URL-friendly identifier
    avatar_url TEXT,
    
    -- Contact Information
    primary_email VARCHAR(255),
    primary_phone VARCHAR(50),
    secondary_contacts JSONB DEFAULT '[]', -- Array of {name, role, email, phone}
    
    -- Metadata
    tags TEXT[] DEFAULT '{}', -- Searchable tags
    internal_notes TEXT, -- Private notes for team
    
    -- Relationships
    department_id UUID REFERENCES departments(id),
    account_manager_id UUID REFERENCES profiles(id),
    created_by UUID REFERENCES profiles(id),
    
    -- Timestamps
    created_at TIMESTAMPTZ DEFAULT NOW(),
    updated_at TIMESTAMPTZ DEFAULT NOW(),
    last_activity_at TIMESTAMPTZ DEFAULT NOW(),
    
    -- Search
    search_vector tsvector GENERATED ALWAYS AS (
        setweight(to_tsvector('english', coalesce(name, '')), 'A') ||
        setweight(to_tsvector('english', coalesce(display_name, '')), 'B') ||
        setweight(to_tsvector('english', coalesce(array_to_string(tags, ' '), '')), 'C')
    ) STORED
);

-- Politician-Specific Information
CREATE TABLE politician_profiles (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    client_id UUID REFERENCES clients(id) ON DELETE CASCADE,
    
    -- Political Information
    party_affiliation VARCHAR(255),
    current_position VARCHAR(255), -- MP, MLA, Minister, etc.
    constituency VARCHAR(255),
    state VARCHAR(100),
    previous_positions JSONB DEFAULT '[]', -- Array of {position, from_date, to_date}
    
    -- Public Profiles
    wikipedia_url TEXT,
    official_website TEXT,
    
    -- Demographics
    date_of_birth DATE,
    place_of_birth VARCHAR(255),
    languages_spoken TEXT[],
    education JSONB DEFAULT '[]', -- Array of {degree, institution, year}
    
    -- Political Stance
    key_focus_areas TEXT[],
    committees JSONB DEFAULT '[]', -- Array of {name, role, from_date}
    
    UNIQUE(client_id)
);

-- Corporate-Specific Information  
CREATE TABLE corporate_profiles (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    client_id UUID REFERENCES clients(id) ON DELETE CASCADE,
    
    -- Company Information
    company_name VARCHAR(255),
    industry VARCHAR(255),
    company_size VARCHAR(50), -- small, medium, large, enterprise
    founded_year INTEGER,
    headquarters_location VARCHAR(255),
    
    -- Key Contacts
    ceo_name VARCHAR(255),
    pr_head_name VARCHAR(255),
    
    -- Business Details
    revenue_range VARCHAR(100),
    employee_count_range VARCHAR(100),
    key_services TEXT[],
    
    UNIQUE(client_id)
);

-- Client Social Media Accounts
CREATE TABLE client_social_accounts (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    client_id UUID REFERENCES clients(id) ON DELETE CASCADE,
    platform VARCHAR(50) NOT NULL, -- twitter, facebook, instagram, etc.
    handle VARCHAR(255) NOT NULL,
    url TEXT,
    is_verified BOOLEAN DEFAULT false,
    follower_count INTEGER,
    is_primary BOOLEAN DEFAULT false,
    last_updated TIMESTAMPTZ DEFAULT NOW()
);

-- Client Guidelines (Do's and Don'ts)
CREATE TABLE client_guidelines (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    client_id UUID REFERENCES clients(id) ON DELETE CASCADE,
    guideline_type VARCHAR(20) CHECK (guideline_type IN ('do', 'dont')),
    category VARCHAR(100), -- communication, topics, branding, etc.
    guideline TEXT NOT NULL,
    priority INTEGER DEFAULT 0, -- Higher number = higher priority
    created_by UUID REFERENCES profiles(id),
    created_at TIMESTAMPTZ DEFAULT NOW()
);

-- Client Documents
CREATE TABLE client_documents (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    client_id UUID REFERENCES clients(id) ON DELETE CASCADE,
    document_type VARCHAR(100), -- brand_guidelines, manifesto, biography, etc.
    title VARCHAR(255) NOT NULL,
    description TEXT,
    file_url TEXT,
    file_size INTEGER,
    mime_type VARCHAR(100),
    uploaded_by UUID REFERENCES profiles(id),
    uploaded_at TIMESTAMPTZ DEFAULT NOW(),
    last_accessed_at TIMESTAMPTZ
);

-- Client Activity Log
CREATE TABLE client_activities (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    client_id UUID REFERENCES clients(id) ON DELETE CASCADE,
    activity_type VARCHAR(50), -- note_added, document_uploaded, status_changed, etc.
    description TEXT,
    metadata JSONB DEFAULT '{}',
    performed_by UUID REFERENCES profiles(id),
    performed_at TIMESTAMPTZ DEFAULT NOW()
);

-- Indexes for performance
CREATE INDEX idx_clients_search ON clients USING GIN(search_vector);
CREATE INDEX idx_clients_department ON clients(department_id);
CREATE INDEX idx_clients_status ON clients(status);
CREATE INDEX idx_clients_type ON clients(client_type);
CREATE INDEX idx_activities_client_date ON client_activities(client_id, performed_at DESC);
```

### 3.2 Row Level Security (RLS) Policies

```sql
-- Enable RLS on all tables
ALTER TABLE clients ENABLE ROW LEVEL SECURITY;
ALTER TABLE politician_profiles ENABLE ROW LEVEL SECURITY;
-- ... (similar for all tables)

-- Clients table policies
CREATE POLICY "Users can view clients in their department" ON clients
    FOR SELECT USING (
        department_id IN (
            SELECT department_id FROM profiles WHERE id = auth.uid()
        ) OR 
        EXISTS (
            SELECT 1 FROM profiles 
            WHERE id = auth.uid() AND role = 'admin'
        )
    );

CREATE POLICY "Only admins and account managers can update clients" ON clients
    FOR UPDATE USING (
        account_manager_id = auth.uid() OR
        EXISTS (
            SELECT 1 FROM profiles 
            WHERE id = auth.uid() AND role = 'admin'
        )
    );
```

